# Copy this file to .env and fill in your values.
# Only the API keys are required for the CLI (scrape.py). Everything else has
# sensible defaults — the tool works with no Obsidian vault and no git.

# ── Required: API keys ───────────────────────────────────────────────────────
# OpenAI — used for Whisper audio transcription
OPENAI_API_KEY=sk-...
# Anthropic — used for Claude research (Haiku for L, Sonnet for M/D)
ANTHROPIC_API_KEY=sk-ant-...

# ── Where notes are written (optional) ───────────────────────────────────────
# Base folder for generated notes. Default: ./notes
# Obsidian users: point this at a folder inside your vault, e.g.
#   OUTPUT_DIR=/home/you/Vault/Clippings
#OUTPUT_DIR=./notes

# Templates folder (Tool.md / Insight.md / RandomFind.md).
# Default: the bundled templates/ folder. Override to use your own.
#TEMPLATE_DIR=./templates

# ── Optional personalization ─────────────────────────────────────────────────
# Tailors the "Project idea" section of Tool notes. Leave blank for generic ideas.
#USER_INTERESTS=machine learning, woodworking, indie game dev
#USER_PROJECTS=my budgeting app, a weather dashboard

# ── Telegram bot (bot.py only) ───────────────────────────────────────────────
# Token from @BotFather
#TELEGRAM_BOT_TOKEN=...
# Your numeric Telegram user ID from @userinfobot. Only this user is allowed.
#TELEGRAM_USER_ID=...

# ── Optional git auto-sync (bot.py) ──────────────────────────────────────────
# If true, the bot commits + pushes each new note. Useful when OUTPUT_DIR is in
# a git-synced Obsidian vault. Default: false (plain local files).
#GIT_SYNC=false
# The git repo to commit/push in. Defaults to VAULT_PATH or OUTPUT_DIR.
#GIT_SYNC_DIR=/home/you/Vault

# ── Back-compat (legacy Obsidian layout) ─────────────────────────────────────
# If set (and OUTPUT_DIR is not), notes go to VAULT_PATH/NOTES_SUBDIR.
#VAULT_PATH=/home/you/Vault
#NOTES_SUBDIR=Clippings/doomScraper
